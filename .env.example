# App
APP_NAME=Xpert Fintech eKYC Platform
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=change-me-in-production

# PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=ekyc_db
POSTGRES_USER=ekyc_user
POSTGRES_PASSWORD=ekyc_pass

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Multi-tenant
DEFAULT_TENANT_SCHEMA=public

# BFIU
BFIU_GUIDELINE=BFIU Circular No. 29
BFIU_MAX_ATTEMPTS_PER_SESSION=10
BFIU_MAX_SESSIONS_PER_DAY=2
