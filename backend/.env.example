# Xpert eKYC Platform — Environment Configuration
# Copy to .env and fill in values before deployment
# NEVER commit .env to git

# ── App ──────────────────────────────────────────────────────────────────
APP_NAME=Xpert Fintech Ltd. - eKYC Compliance API
APP_VERSION=1.0.0
DEBUG=False
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_64_CHAR_STRING

# ── Database ─────────────────────────────────────────────────────────────
# Development (SQLite):
DATABASE_URL=sqlite:///./ekyc.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql://ekyc_user:STRONG_PASSWORD@localhost:5432/ekyc_db
SQL_ECHO=false

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT RS256 Keys ───────────────────────────────────────────────────────
# Generate with: openssl genrsa -out keys/private.pem 2048
# openssl rsa -in keys/private.pem -pubout -out keys/public.pem
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── BFIU ─────────────────────────────────────────────────────────────────
BFIU_GUIDELINE=BFIU Circular No. 29
BFIU_MAX_ATTEMPTS_PER_SESSION=10
BFIU_MAX_SESSIONS_PER_DAY=2

# ── EC / Porichoy API ────────────────────────────────────────────────────
NID_API_MODE=DEMO   # DEMO | LIVE
NID_API_BASE_URL=https://nid.ec.gov.bd/api/v1
NID_API_KEY=YOUR_PORICHOY_API_KEY_HERE
NID_API_SECRET=YOUR_PORICHOY_API_SECRET_HERE

# ── SMS Gateway ──────────────────────────────────────────────────────────
SMS_API_KEY=YOUR_SMS_GATEWAY_API_KEY
SMS_API_URL=https://api.sms.net.bd/send

# ── SMTP ─────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourcompany.com
SMTP_PASSWORD=YOUR_APP_PASSWORD
SMTP_FROM=noreply@yourcompany.com

# ── CORS ─────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://ekyc.yourcompany.com,https://www.yourcompany.com

# ── Face Matching Thresholds ─────────────────────────────────────────────
MATCH_THRESHOLD=45.0
REVIEW_THRESHOLD=30.0
